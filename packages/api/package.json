{
  "private": true,
  "type": "module",
  "name": "api",
  "scripts": {
    "build": "tsc --build tsconfig.json",
    "predev": "npm run build",
    "dev": "./bin/env.sh node --watch dist/src/index.js",
    "tsc": "tsc --build tsconfig.test.json",
    "vitest": "vp test --config=./vite.config.ts",
    "test": "concurrently \"npm run tsc\" \"npm run vitest\"",
    "test-ci": "vp test run --config=./vite.config.ts --maxWorkers=1",
    "format": "vp fmt package.json src bin test --write",
    "format-check": "vp fmt package.json src bin test --check",
    "lint": "vp lint src bin test",
    "lint-fix": "vp lint src bin test --fix"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.11",
    "@prisma/adapter-pg": "^7.6.0",
    "hono": "^4.12.9",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "concurrently": "^9.2.1",
    "typescript": "^6.0.2"
  }
}

{
  "compilerOptions": {
    "types": ["node"],
    "incremental": true,
    "strict": true,
    "outDir": "dist",
    "sourceMap": true,
    "esModuleInterop": true,
    "target": "esnext",
    "lib": ["ESNext"],
    "module": "nodenext",
    "skipLibCheck": true,
    "rootDir": "./",
    "paths": {
      "shared": ["../shared"]
    }
  },
  "exclude": ["dist", "node_modules", "test", "**/*.test.ts"],
  "references": [{ "path": "../shared" }]
}

{
  "private": true,
  "name": "bin",
  "type": "module",
  "scripts": {
    "init-local": "node ./src/index.ts init-local",
    "env": "node --no-warnings=ExperimentalWarning ./src/index.ts env",
    "docker-compose": "node --no-warnings=ExperimentalWarning ./src/index.ts docker-compose",
    "test": "",
    "format": "vp fmt package.json src --write",
    "format-check": "vp fmt package.json src --check",
    "lint": "vp lint src",
    "lint-fix": "vp lint src --fix"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^6.0.2"
  }
}
